# ============================================================================
# 环境变量配置模板
# ============================================================================
# 使用方法:
#   本地开发:
#     cp .env.example .env
#     # 编辑 .env 填入真实值
#     # .env 已加入 .gitignore，不会提交到仓库
#
#   K8s 部署 (手动):
#     NAMESPACE=mb-test ./deployment/scripts/create-k8s-secrets.sh .env
#     (或先 source .env，再执行脚本)
#
#   Jenkins CI/CD:
#     Jenkins 凭据管理 → 创建对应 credentialsId → 流水线自动注入
#     credentialsId 列表: kf-deepseek-api-key, kf-api-key, kf-embed-api-key, ...
# ============================================================================

# ── LLM 供应商密钥 ──
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── kf-embed 微服务 ──
EMBED_BASE_URL=http://localhost:8100/v1
EMBED_MODEL=nomic-embed-text
EMBED_API_KEY=

# ── Qdrant 向量库 ──
QDRANT_HOST=localhost
QDRANT_PORT=6334

# ── API 网关鉴权 ──
KF_API_KEY=

# ── Redis 会话存储 ──
REDIS_URL=redis://localhost:6379/0

# ── MySQL RDS (主库 / metrics) ──
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=kfpass
MYSQL_DB=kf_metrics
KF_METRICS_DB_HOST=127.0.0.1
KF_METRICS_DB_PORT=3307
KF_METRICS_DB_USER=root
KF_METRICS_DB_PASSWORD=kfpass
KF_METRICS_DB_NAME=kf_metrics
KF_METRICS_DB_TYPE=mysql

# ── PostgreSQL RDS (分析库) ──
PG_HOST=127.0.0.1
PG_PORT=5433
PG_USER=postgres
PG_PASSWORD=kfpass
PG_DB=kf_analytics

# ── OSS 凭据 ──
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_WORKFLOW_BUCKET=kf-workflow
OSS_UI_BUCKET=kf-ui
OSS_PATH_PREFIX=mb-test
